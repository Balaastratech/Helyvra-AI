# Copy to .env. Defaults already match your GCP project — edit only if needed.

# --- Vertex AI (NO API KEY; auth via ADC) ---
VERTEXAI_PROJECT=ai-negotiation-copilot
VERTEXAI_LOCATION=us-central1
GOOGLE_CLOUD_PROJECT=ai-negotiation-copilot

# Models
EXTRACTION_MODEL=gemini-2.5-flash
JUDGE_MODEL=gemini-2.5-pro
# Cheaper extraction option to try later: gemini-3.1-flash-lite

# --- Embeddings: local & free ---
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# --- Cognee storage (Windows MAX_PATH fix: keep SHORT) ---
COGNEE_SYS_DIR=C:\cg\sys
COGNEE_DATA_DIR=C:\cg\data

# Cognee's 'custom' provider requires a NON-EMPTY key as a config-gate. Vertex does
# NOT use it (auth is ADC) — LiteLLM ignores api_key on the vertex_ai/ path. Dummy is fine.
LLM_API_KEY=vertex-adc
