# Copy to .env and fill in. Pick ONE LLM provider for cognify/extraction.

# --- Option A: OpenAI (simplest, paid) ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# --- Option B: Gemini Flash (cheap; cost-safe default) ---
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=...

# --- Option C: DeepSeek (cheap, OpenAI-compatible endpoint) ---
# LLM_PROVIDER=openai
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=...
# LLM_ENDPOINT=https://api.deepseek.com/v1

# --- Embeddings: LOCAL & FREE (keeps spend near $0) ---
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
